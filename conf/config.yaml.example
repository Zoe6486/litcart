name: "litcart"
mode: "release"
port: 8084
version: "v0.0.1"
start_time: "2020-07-01"
machine_id: 1

auth:
  jwt_expire: 8760

log:
  level: "info"
  filename: "web_app.log"
  max_size: 200
  max_age: 30
  max_backups: 7

mysql:
  host: YOUR_MYSQL_HOST
  port: 3306
  user: YOUR_MYSQL_USER
  password: YOUR_MYSQL_PASSWORD
  dbname: db_litcart
  max_open_conns: 200
  max_idle_conns: 50

redis:
  host: YOUR_REDIS_HOST
  port: 6379
  password: YOUR_REDIS_PASSWORD
  db: 0
  pool_size: 100